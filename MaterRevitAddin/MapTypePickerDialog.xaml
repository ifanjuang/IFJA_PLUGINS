<Window x:Class="Mater2026.MapTypePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Map Type"
        Width="400" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Unrecognized file:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" x:Name="FileNameText" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="#555"/>

        <TextBlock Grid.Row="2" Text="Assign as:" Margin="0,0,0,5"/>

        <ListBox Grid.Row="3" x:Name="TypeList" Margin="0,0,0,15" SelectionMode="Single">
            <ListBoxItem Content="Preview (thumbnail)" Tag="Preview" IsSelected="True"/>
            <ListBoxItem Content="Albedo (diffuse)" Tag="Albedo"/>
            <ListBoxItem Content="Bump / Normal / Depth" Tag="Bump"/>
            <ListBoxItem Content="Roughness" Tag="Roughness"/>
            <ListBoxItem Content="Reflection (metallic)" Tag="Reflection"/>
            <ListBoxItem Content="Refraction (opacity)" Tag="Refraction"/>
            <ListBoxItem Content="Illumination (emissive)" Tag="Illumination"/>
        </ListBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28" IsDefault="True" Click="OK_Click"
                    Background="Black" Foreground="White" FontWeight="Bold" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="28" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
